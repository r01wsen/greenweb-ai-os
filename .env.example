# ============================================================
# AgriSphere / GreenWeb AI OS - Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ── Supabase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── AI Models (at least one required) ───────────────────────────────────────
# OpenAI - used for GPT-4o vision, Whisper voice, and report generation
OPENAI_API_KEY=sk-...

# Anthropic - used as fallback for vision and report generation
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe Billing (required for paid plans) ────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create these in Stripe Dashboard)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── n8n IoT Orchestrator ─────────────────────────────────────────────────────
# Your self-hosted n8n instance URL
N8N_WEBHOOK_URL=https://n8n.yourdomain.com/webhook
N8N_WEBHOOK_SECRET=your_shared_webhook_secret

# ── Video Conferencing (choose one) ──────────────────────────────────────────
# Whereby
WHEREBY_API_KEY=your_whereby_api_key

# Twilio Video (alternative)
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# ── App Config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.vercel.app

# ── Optional: Local Ollama (for private AI inference) ────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Optional: FastAPI Backend ────────────────────────────────────────────────
FASTAPI_URL=http://localhost:8000
FASTAPI_SECRET=your_internal_api_secret
